{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Pulsar",
  "version": "0.1.0",
  "identifier": "com.slamanna.pulsar",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Pulsar",
        "width": 1180,
        "height": 860,
        "minWidth": 300,
        "minHeight": 80,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
