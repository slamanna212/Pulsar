{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Apogee",
  "version": "../package.json",
  "identifier": "com.slamanna.apogee",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/fetch-mpv.mjs auto"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Apogee",
        "width": 1180,
        "height": 810,
        "minWidth": 300,
        "minHeight": 72,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": true,
        "center": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https: http:; img-src 'self' asset: http://asset.localhost https: http: data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/slamanna212/Apogee/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVBRUU0QzZFMjBCMkQ4NjEKUldSaDJMSWdia3p1V3RkR3p3MEhEZmtlWnJuUlJuV3lxdlpNb200T0NINTIvTGVzWXNzRmRObzcK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["deb", "rpm", "appimage", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "depends": ["mpv"]
      },
      "rpm": {
        "depends": ["mpv"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
