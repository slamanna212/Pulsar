{
  "name": "apogee",
  "private": true,
  "version": "0.1.0-alpha.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "tauri": "tauri",
    "fetch:mpv:windows": "node scripts/fetch-mpv.mjs windows",
    "fetch:mpv:appimage": "node scripts/fetch-mpv.mjs appimage",
    "tauri:build:windows": "npm run fetch:mpv:windows && tauri build",
    "tauri:build:linux": "tauri build --bundles deb,rpm && npm run fetch:mpv:appimage && tauri build --bundles appimage --config src-tauri/tauri.appimage.conf.json",
    "tauri:build:mac": "tauri build"
  },
  "dependencies": {
    "@fontsource/sora": "^5.2.8",
    "@fontsource/space-grotesk": "^5.2.10",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tabler/icons-react": "^3.44.0",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-store": "^2.4.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tslib": "^2.8.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "7zip-min": "^3.0.1",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
